<Window x:Class="Wyspa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Wyspa.Core.Models;assembly=Wyspa.Core"
        Title="Wyspa"
        Icon="Assets/AppIcon.ico"
        Width="700"
        Height="520"
        MinWidth="560"
        MinHeight="480"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="6">
        <Border Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="7">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="1,0,1,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Assets/AppLogo.png" Width="32" Height="32" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Wyspa" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource InkBrush}" />
                            <TextBlock Text="{Binding ConnectionMessage}" Foreground="{DynamicResource MutedBrush}" FontSize="11.5" TextTrimming="CharacterEllipsis" MaxWidth="430" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="1" TabStripPlacement="Left">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE80F;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Home" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="420" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Control Center" Style="{StaticResource SectionTitle}" Margin="0" />
                                        <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Control Center&#x0a;- Start or stop dictation.&#x0a;- Open Groq setup links.&#x0a;- Open the scratchpad test area.">
                                            <TextBlock Style="{StaticResource HeaderHelpText}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Start dictation and check your current setup." Style="{StaticResource BodyText}" Margin="0,0,0,5" />
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Dictation" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Dictation&#x0a;- Uses the selected trigger mode from Input.&#x0a;- Disabled until an API Key is saved.&#x0a;- Use this for quick manual testing.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding HotkeyText}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,1,0,5" />
                                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleListeningCommand}" IsEnabled="{Binding CanListen}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE720;" Margin="0,0,7,0" />
                                                    <TextBlock Text="{Binding ToggleText}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Groq Setup" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Groq Setup&#x0a;- Open Groq or the API Keys page.&#x0a;- Create a key in Groq Console.&#x0a;- Paste it in the Groq tab and test it.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Create an API Key, paste it in Groq, then test the connection." Style="{StaticResource BodyText}" Margin="0,2,0,4" />
                                            <TextBlock Style="{StaticResource BodyText}">
                                                <Hyperlink NavigateUri="https://groq.com/" RequestNavigate="Hyperlink_OnRequestNavigate">Groq Website</Hyperlink>
                                                <Run Text="  |  " />
                                                <Hyperlink NavigateUri="https://console.groq.com/keys" RequestNavigate="Hyperlink_OnRequestNavigate">API Keys</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Scratchpad" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Scratchpad&#x0a;- Test transcription inside Wyspa.&#x0a;- Check cleanup and re-write output.&#x0a;- Does not insert into another app.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Open a compact test pad for Groq transcription without inserting text." Style="{StaticResource BodyText}" Margin="0,2,0,5" />
                                            <Button Style="{StaticResource PrimaryButton}" Click="OpenScratchpadButton_OnClick" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE9A1;" Margin="0,0,7,0" />
                                                    <TextBlock Text="Open Scratchpad" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE753;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Groq" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="430" HorizontalAlignment="Left">
                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Get an API Key" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Get an API Key&#x0a;- Open the Groq Console.&#x0a;- Create a key from API Keys.&#x0a;- Wyspa stores it encrypted for your Windows user.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource BodyText}" Margin="0,3,0,0">
                                            <Run Text="Open " />
                                            <Hyperlink NavigateUri="https://groq.com/" RequestNavigate="Hyperlink_OnRequestNavigate">Groq</Hyperlink>
                                            <Run Text=" or " />
                                            <Hyperlink NavigateUri="https://console.groq.com/keys" RequestNavigate="Hyperlink_OnRequestNavigate">API Keys</Hyperlink>
                                            <Run Text=", sign in, create a key, copy it, paste it here, then test connection." />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Groq Connection" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Groq Connection&#x0a;- Saves and tests your API Key.&#x0a;- Chooses the speech-to-text model.&#x0a;- Adds optional language and vocabulary hints.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="API Key&#x0a;- Required before any listening can start.&#x0a;- Displayed as dots when a saved key exists.&#x0a;- Remove Key deletes Wyspa's saved copy.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <PasswordBox x:Name="ApiKeyBox"
                                                     PasswordChanged="ApiKeyBox_OnPasswordChanged"
                                                     GotKeyboardFocus="ApiKeyBox_OnGotKeyboardFocus"
                                                     LostKeyboardFocus="ApiKeyBox_OnLostKeyboardFocus" />
                                        <WrapPanel>
                                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding TestConnectionCommand}" Content="Test Connection" />
                                            <Button Command="{Binding RemoveKeyCommand}" Content="Remove Key" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding ConnectionMessage}" Style="{StaticResource BodyText}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Model" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Model&#x0a;- Groq speech-to-text model ID.&#x0a;- Default is optimized for fast Whisper transcription.&#x0a;- Change only if Groq lists a compatible audio model.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBox Text="{Binding Settings.ModelId, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Language" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Language&#x0a;- Optional language hint for transcription.&#x0a;- Use a short code like en when helpful.&#x0a;- Leave blank to let the model auto-detect.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBox Text="{Binding Settings.Language, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Vocabulary Prompt" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Vocabulary Prompt&#x0a;- Optional hint for names, terms, or jargon.&#x0a;- Helps Groq choose expected spellings.&#x0a;- Keep it short and specific.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBox Text="{Binding Settings.CustomPrompt, UpdateSourceTrigger=PropertyChanged}" MaxLength="500" AcceptsReturn="True" Height="48" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE720;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Input" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Microphone" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Microphone&#x0a;- Select the Windows input device Wyspa records from.&#x0a;- Refresh after plugging in or changing devices.&#x0a;- The level meter runs even outside AutoCapture.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <ComboBox ItemsSource="{Binding Devices}"
                                                  SelectedValue="{Binding Settings.MicrophoneDeviceId, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Name" />
                                        <WrapPanel Margin="0,0,0,0">
                                            <Button Command="{Binding RefreshDevicesCommand}" Content="Refresh" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Capture &amp; Shortcuts" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Capture &amp; Shortcuts&#x0a;- Choose how recording starts.&#x0a;- Calibrate AutoCapture against your room noise.&#x0a;- Record global shortcuts by clicking the field, pressing keys, then saving.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Mode" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Mode&#x0a;- Toggle: press once to start, press again to stop.&#x0a;- Hold to Talk: record only while the shortcut is held.&#x0a;- AutoCapture: listens for speech above the threshold.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <ComboBox SelectedValue="{Binding Settings.ActivationMode}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="Toggle" Tag="{x:Static models:ActivationMode.Toggle}" />
                                            <ComboBoxItem Content="Hold to Talk" Tag="{x:Static models:ActivationMode.HoldToTalk}" />
                                            <ComboBoxItem Content="AutoCapture" Tag="{x:Static models:ActivationMode.AutoCapture}" />
                                        </ComboBox>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="AutoCapture Calibration" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="AutoCapture Calibration&#x0a;- Meter shows current microphone level.&#x0a;- Slider sets the trigger threshold from 0% to 100%.&#x0a;- Raise it if small noises start recording; lower it if speech is missed.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding MicrophoneLevelText}" Style="{StaticResource BodyText}" />
                                            <TextBlock Grid.Column="1"
                                                       Style="{StaticResource BodyText}"
                                                       Text="{Binding Value, ElementName=AutoCaptureThresholdSlider, StringFormat=Trigger {0:P0}}" />
                                        </Grid>
                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding MicrophoneLevel, Mode=OneWay}" Height="8" Margin="0,2,0,4" />
                                        <Slider x:Name="AutoCaptureThresholdSlider"
                                                Minimum="0"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                Value="{Binding Settings.AutoCaptureThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Silence Before Stop (ms)" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Silence Before Stop&#x0a;- How long AutoCapture waits after you stop speaking.&#x0a;- Lower values finish faster.&#x0a;- Higher values allow longer pauses mid-sentence.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBox Text="{Binding Settings.AutoCaptureSilenceMs, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Content="AutoCapture Listening Enabled"
                                                  IsChecked="{Binding Settings.AutoCaptureListeningEnabled}"
                                                  ToolTip="Turns AutoCapture's always-listening state on or off. This can also be toggled from the tray menu or the AutoCapture listening shortcut." />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Current Shortcut" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Current Shortcut&#x0a;- Click the box and press the shortcut.&#x0a;- Save Hotkey finishes recording it.&#x0a;- F13-F24 macro keys can be used without modifiers.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="HotkeyRecorderBox"
                                                     Text="{Binding HotkeyText, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     GotKeyboardFocus="HotkeyRecorderBox_OnGotKeyboardFocus" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="SaveHotkeyButton_OnClick"
                                                    Margin="7,2,0,5"
                                                    Content="Save Hotkey" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="AutoCapture Listening Shortcut" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="AutoCapture Listening Shortcut&#x0a;- Toggles AutoCapture listening on or off.&#x0a;- Gives tone and overlay feedback when changed.&#x0a;- Only applies to AutoCapture mode.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="AutoCaptureHotkeyRecorderBox"
                                                     Text="{Binding AutoCaptureHotkeyText, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     GotKeyboardFocus="AutoCaptureHotkeyRecorderBox_OnGotKeyboardFocus" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="SaveAutoCaptureHotkeyButton_OnClick"
                                                    Margin="7,2,0,5"
                                                    Content="Save Hotkey" />
                                        </Grid>
                                        <TextBlock Text="Click a shortcut field, press your shortcut, then save it. F13-F24 macro keys can be used without modifiers." Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,8,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Wake Voice" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Wake Voice&#x0a;- Optional local voice gate for AutoCapture.&#x0a;- Requires a trained Hey Whisper style phrase.&#x0a;- Disabled settings below do nothing until this is turned on.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <CheckBox Content="Require Local Hey Whisper Match"
                                                  IsChecked="{Binding Settings.AutoCaptureWakeVoiceEnabled}"
                                                  ToolTip="When enabled, AutoCapture waits for a local wake voice match before it records dictated text." />
                                        <StackPanel IsEnabled="{Binding IsWakeVoiceSettingsEnabled}">
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Wake Match Strictness" Style="{StaticResource FieldLabel}" />
                                                    <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Wake Match Strictness&#x0a;- 0% accepts looser matches.&#x0a;- 100% requires a closer voice match.&#x0a;- Train first, then adjust only if it misses or triggers too easily.">
                                                        <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Style="{StaticResource BodyText}"
                                                           Text="{Binding Value, ElementName=WakeVoiceSensitivitySlider, StringFormat={}{0:P0}}" />
                                            </Grid>
                                            <Slider x:Name="WakeVoiceSensitivitySlider"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    TickFrequency="0.01"
                                                    Value="{Binding Settings.AutoCaptureWakeVoiceSensitivity, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding WakeTrainingProgressText}" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Wake Voice Training&#x0a;- Record each displayed phrase in your normal voice.&#x0a;- Include the wake phrase and sample sentences.&#x0a;- Reset Training clears the local voice profile.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <Border Background="{DynamicResource PanelAltBrush}"
                                                    BorderBrush="{DynamicResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8"
                                                    Margin="0,0,0,5">
                                                <TextBlock Text="{Binding WakeTrainingPromptText}"
                                                           Foreground="{DynamicResource InkBrush}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <WrapPanel Margin="0,2,0,3">
                                                <Button Style="{StaticResource PrimaryButton}"
                                                        Command="{Binding RecordWakeVoiceCommand}"
                                                        Content="{Binding WakeVoiceButtonText}" />
                                                <Button Command="{Binding ResetWakeVoiceCommand}"
                                                        Content="Reset Training" />
                                            </WrapPanel>
                                            <TextBlock Text="{Binding WakeTrainingText}" Style="{StaticResource BodyText}" Margin="0,0,0,3" />
                                            <TextBlock Text="{Binding WakeVoiceStatus}" Style="{StaticResource BodyText}" Margin="0,0,0,5" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Wake Accepted Tone" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Wake Accepted Tone&#x0a;- Plays when wake voice successfully starts listening.&#x0a;- Use Default restores Wyspa's built-in short tone.&#x0a;- Choose WAV lets you use your own local sound.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <CheckBox Content="Play a short tone when Wyspa starts listening"
                                                      IsChecked="{Binding Settings.WakeToneEnabled}"
                                                      ToolTip="Turns the wake accepted tone on or off. The recording still starts when off; it is just silent." />
                                            <TextBlock Text="{Binding WakeToneText}" Style="{StaticResource BodyText}" TextTrimming="CharacterEllipsis" Margin="0,0,0,3" />
                                            <WrapPanel Margin="0,0,0,0">
                                                <Button Click="ChooseWakeToneButton_OnClick" Content="Choose WAV" />
                                                <Button Click="ResetWakeToneButton_OnClick" Content="Use Default" />
                                                <Button Click="TestWakeToneButton_OnClick" Content="Test Tone" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE9D2;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Behavior" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Dictation Behavior" Style="{StaticResource SectionTitle}" Margin="0" />
                                    <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Dictation Behavior&#x0a;- Clean raw transcription text.&#x0a;- Optionally re-write it with Groq.&#x0a;- Choose insertion, spoken actions, and overlay behavior.">
                                        <TextBlock Style="{StaticResource HeaderHelpText}" />
                                    </Border>
                                </StackPanel>

                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Basic Cleanup" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Basic Cleanup&#x0a;- Runs locally before any optional AI re-write.&#x0a;- Cleans spacing and obvious transcript artifacts.&#x0a;- Spoken punctuation can turn words like comma into punctuation.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <CheckBox Content="Clean Up Transcripts"
                                                  IsChecked="{Binding Settings.CleanupEnabled}"
                                                  ToolTip="Turns local cleanup on or off before the text is inserted or sent for optional re-write." />
                                        <CheckBox Content="Convert Spoken Punctuation"
                                                  IsChecked="{Binding Settings.SpokenPunctuationEnabled}"
                                                  ToolTip="Converts spoken punctuation words such as comma, period, new line, and question mark when cleanup is enabled." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Tone Re-write" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Tone Re-write&#x0a;- Optional Groq text pass after transcription.&#x0a;- Turns spoken wording into cleaner written text.&#x0a;- Uses the selected tone prompt and model.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <CheckBox Content="Re-write Dictated Text with Groq"
                                                  IsChecked="{Binding Settings.GroqWritingCleanupEnabled}"
                                                  ToolTip="When enabled, Wyspa sends the transcript to the selected Groq text model for polishing. Disabled means transcription is inserted directly after local cleanup." />
                                        <StackPanel IsEnabled="{Binding IsWritingCleanupSettingsEnabled}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Tone" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Tone&#x0a;- Formal: polished, professional wording.&#x0a;- Casual: natural everyday writing.&#x0a;- Technical: clearer structure for technical notes, support text, and instructions.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <ComboBox SelectedValue="{Binding Settings.WritingCleanupTone}" SelectedValuePath="Tag">
                                                <ComboBoxItem Content="Formal" Tag="{x:Static models:WritingCleanupTone.Formal}" />
                                                <ComboBoxItem Content="Casual" Tag="{x:Static models:WritingCleanupTone.Casual}" />
                                                <ComboBoxItem Content="Technical" Tag="{x:Static models:WritingCleanupTone.Technical}" />
                                            </ComboBox>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Tone Re-write Model" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Tone Re-write Model&#x0a;- Groq chat model used for text polishing.&#x0a;- Smaller models are usually cheaper and faster.&#x0a;- The speech-to-text model is configured separately in Groq.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBox Text="{Binding Settings.WritingCleanupModelId, UpdateSourceTrigger=PropertyChanged}" />
                                            <Expander Margin="0,3,0,0">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Tone Re-write Prompts" />
                                                        <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Tone Re-write Prompts&#x0a;- Edit the instruction used for each tone.&#x0a;- Leave a prompt blank to use Wyspa's default.&#x0a;- Keep prompts focused on the writing style you want.">
                                                            <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                        </Border>
                                                    </StackPanel>
                                                </Expander.Header>
                                                <StackPanel Margin="0,6,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Formal Prompt" Style="{StaticResource FieldLabel}" />
                                                        <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Formal Prompt&#x0a;- Best for emails, messages, and professional wording.&#x0a;- Usually removes filler words and improves sentence flow.">
                                                            <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Settings.FormalRewritePrompt, UpdateSourceTrigger=LostFocus}"
                                                             AcceptsReturn="True"
                                                             Height="86"
                                                             TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Casual Prompt" Style="{StaticResource FieldLabel}" />
                                                        <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Casual Prompt&#x0a;- Best for friendly messages.&#x0a;- Keeps the meaning natural without becoming too formal.">
                                                            <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Settings.CasualRewritePrompt, UpdateSourceTrigger=LostFocus}"
                                                             AcceptsReturn="True"
                                                             Height="86"
                                                             TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Technical Prompt" Style="{StaticResource FieldLabel}" />
                                                        <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Technical Prompt&#x0a;- Best for procedures, bug notes, or technical explanations.&#x0a;- Encourages clearer structure and precise wording.">
                                                            <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Settings.TechnicalRewritePrompt, UpdateSourceTrigger=LostFocus}"
                                                             AcceptsReturn="True"
                                                             Height="86"
                                                             TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Text Insertion" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Text Insertion&#x0a;- Chooses how final text reaches the active app.&#x0a;- Optional clipboard retention helps when no text field was focused.&#x0a;- Paste mode is usually fastest.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Insertion Mode" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Insertion Mode&#x0a;- Paste with Clipboard Restore: fast paste, then tries to restore previous clipboard.&#x0a;- Type Characters: sends keystrokes one by one for apps that block paste.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <ComboBox SelectedValue="{Binding Settings.InsertionMode}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="Paste with Clipboard Restore" Tag="{x:Static models:InsertionMode.Paste}" />
                                            <ComboBoxItem Content="Type Characters" Tag="{x:Static models:InsertionMode.Type}" />
                                        </ComboBox>
                                        <CheckBox Content="Keep Inserted Text on Clipboard for Manual Paste"
                                                  IsChecked="{Binding Settings.CopyInsertedTextToClipboard}"
                                                  ToolTip="Keeps the latest inserted text on the clipboard so you can paste it manually if the wrong app or no text box was focused." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Spoken Actions" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Spoken Actions&#x0a;- Lets Wyspa perform clear commands instead of inserting text.&#x0a;- Examples: copy, paste, Enter, Escape, Task View.&#x0a;- Turn this off for pure transcribe-and-insert behavior.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <CheckBox Content="Enable Spoken Commands and Groq Intent Actions"
                                                  IsChecked="{Binding Settings.IntentActionsEnabled}"
                                                  ToolTip="When enabled, Wyspa may execute supported actions from clear spoken commands. When disabled, it only inserts transcript text." />
                                        <StackPanel IsEnabled="{Binding IsIntentSettingsEnabled}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Intent Model" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Intent Model&#x0a;- Groq chat model used to decide whether speech is a command.&#x0a;- Separate from transcription and tone re-write models.&#x0a;- Lower latency models make actions feel faster.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBox Text="{Binding Settings.IntentModelId, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Action Confidence Threshold" Style="{StaticResource FieldLabel}" />
                                                <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Action Confidence Threshold&#x0a;- Higher means fewer accidental actions.&#x0a;- Lower means commands trigger more easily.&#x0a;- Increase it if normal speech is being treated as a command.">
                                                    <TextBlock Style="{StaticResource HeaderHelpText}" />
                                                </Border>
                                            </StackPanel>
                                            <Slider Minimum="0.1"
                                                    Maximum="0.95"
                                                    TickFrequency="0.05"
                                                    IsSnapToTickEnabled="False"
                                                    Value="{Binding Settings.IntentConfidenceThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Allowed actions: copy, paste, cut, select all, undo, redo, Enter, Tab, Escape, Backspace, Delete, Task View." Style="{StaticResource BodyText}" Margin="0,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Overlay" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Overlay&#x0a;- Shows recording and listening feedback.&#x0a;- Waveform stays visible even if the background is transparent.&#x0a;- AutoCapture toggles can briefly show listening on/off.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Overlay Background Opacity" Style="{StaticResource FieldLabel}" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Overlay Background Opacity&#x0a;- 0% hides only the background box.&#x0a;- 100% makes the box fully opaque.&#x0a;- Waveform and text remain visible.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Text="{Binding Value, ElementName=OverlayOpacitySlider, StringFormat=Background {0:P0}}" />
                                        <Slider x:Name="OverlayOpacitySlider"
                                                Minimum="0"
                                                Maximum="1"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding Settings.OverlayOpacity, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="0% hides the box only; the waveform and text stay visible." Style="{StaticResource BodyText}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE72E;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Privacy" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Privacy" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Privacy&#x0a;- Controls optional local transcript and audio retention.&#x0a;- Remove API Key deletes the saved Groq key.&#x0a;- Clear History removes locally stored transcript history.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Wyspa sends microphone audio, model ID, and optional language/prompt to Groq. It does not take screenshots, capture active-window context, log transcripts, or keep raw audio by default." Style="{StaticResource BodyText}" Margin="0,2,0,5" />
                                        <CheckBox Content="Keep Local Transcript History"
                                                  IsChecked="{Binding Settings.HistoryEnabled}"
                                                  ToolTip="Stores local transcript history when enabled. Leave off if you do not want dictated text retained by Wyspa." />
                                        <CheckBox Content="Retain Raw Audio for Debugging"
                                                  IsChecked="{Binding Settings.RetainAudioForDebugging}"
                                                  ToolTip="Keeps captured audio files for troubleshooting when enabled. Leave off for the normal privacy-first mode." />
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Command="{Binding ClearHistoryCommand}" Content="Clear History" />
                                            <Button Command="{Binding RemoveKeyCommand}" Content="Remove API Key" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE7F4;" Width="24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="System" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer Padding="8">
                            <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                                <Border Style="{StaticResource Card}" Margin="0,0,0,7">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Startup" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Startup&#x0a;- Start Minimized opens Wyspa to the tray.&#x0a;- Start with Windows runs it when your Windows user signs in.&#x0a;- Tray and app settings stay in sync.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <CheckBox Content="Start Minimized"
                                                  IsChecked="{Binding Settings.StartMinimized}"
                                                  ToolTip="When enabled, Wyspa opens quietly in the system tray instead of showing the main window." />
                                        <CheckBox Content="Start with Windows"
                                                  IsChecked="{Binding StartWithWindows}"
                                                  ToolTip="Adds or removes Wyspa from the current user's Windows startup registry entry." />
                                        <TextBlock Text="Start with Windows uses the current Windows user startup registry entry." Style="{StaticResource BodyText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Updates" Foreground="{DynamicResource InkBrush}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource HeaderHelpIcon}" ToolTip="Updates&#x0a;- Check for Updates compares this app version with GitHub releases.&#x0a;- Download Update opens the newer installer when available.&#x0a;- Running a newer installer updates the existing install.">
                                                <TextBlock Style="{StaticResource HeaderHelpText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding AppVersionText}" Style="{StaticResource BodyText}" Margin="0,2,0,3" />
                                        <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource BodyText}" Margin="0,0,0,4" />
                                        <WrapPanel>
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding CheckForUpdatesCommand}"
                                                    Content="Check for Updates" />
                                            <Button Command="{Binding OpenUpdateCommand}"
                                                    IsEnabled="{Binding IsUpdateAvailable}"
                                                    Content="Download Update" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>
