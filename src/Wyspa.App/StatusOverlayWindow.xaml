<Window x:Class="Wyspa.App.StatusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="250"
        Height="78"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Border x:Name="Shell"
            CornerRadius="12"
            Background="#CCFFFFFF"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="12,9">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid x:Name="WaveformGrid" Height="28" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border x:Name="Bar1" Grid.Column="0" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar2" Grid.Column="1" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar3" Grid.Column="2" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar4" Grid.Column="3" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar5" Grid.Column="4" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar6" Grid.Column="5" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar7" Grid.Column="6" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar8" Grid.Column="7" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar9" Grid.Column="8" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar10" Grid.Column="9" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar11" Grid.Column="10" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
                <Border x:Name="Bar12" Grid.Column="11" Width="5" Height="4" CornerRadius="2.5" Background="#2B7A78" VerticalAlignment="Center" />
            </Grid>
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Text="Listening"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#172025" />
        </Grid>
    </Border>
</Window>
